{
  "name": "eco-ai-server",
  "version": "1.0.0",
  "description": "Eco AI Tracker - Express + MongoDB Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js"
  },
  "nodemonConfig": {
    "watch": ["."],
    "ext": "js,json",
    "ignore": ["node_modules"],
    "delay": "1000"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.3",
    "mongodb-memory-server": "^11.0.1",
    "mongoose": "^8.5.0",
    "openai": "^6.34.0",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
