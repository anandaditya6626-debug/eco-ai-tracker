# MongoDB Atlas connection string
# Get this from: https://cloud.mongodb.com → your cluster → Connect → Drivers
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/eco-ai-tracker?retryWrites=true&w=majority
